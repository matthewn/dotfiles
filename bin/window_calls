#!/bin/bash
#
# most functions require the Window Calls GNOME extension
# https://github.com/ickyicky/window-calls
#
# We use two dbus tools, picked per call:
#   - dbus-send --print-reply=literal: for JSON-returning reads (List,
#     GetFrameRect). Outputs raw JSON ready for jq, no unwrapping needed.
#   - gdbus call: for everything else (MoveResize, Activate, GetCurrentState).
#     gdbus infers argument types from introspection, so we pass plain
#     positional args; dbus-send would need a typed prefix on each one
#     (uint32:.., int32:..), which is noisy for the 5-arg MoveResize.

# winid_from_class WM_CLASS
#   Print the id of the first window whose wm_class equals WM_CLASS.
#   On no match, prints the sentinel "MISSING:class:WM_CLASS" so callers
#   can report what was searched for.
winid_from_class () {
    local id
    id=$(dbus-send --session --print-reply=literal \
        --dest=org.gnome.Shell \
        /org/gnome/Shell/Extensions/Windows \
        org.gnome.Shell.Extensions.Windows.List \
        | jq -r --arg target "$1" '.[] | select(.wm_class == $target) | .id' \
        | head -n1)
    if [ -z "$id" ]; then
        echo "MISSING:class:$1"
    else
        echo "$id"
    fi
}

# winid_from_title TITLE_REGEX
#   Print the id of the first window whose title matches TITLE_REGEX
#   (jq regex via test()). On no match, prints the sentinel
#   "MISSING:title:TITLE_REGEX" so callers can report what was searched for.
winid_from_title () {
    local id
    id=$(dbus-send --session --print-reply=literal \
        --dest=org.gnome.Shell \
        /org/gnome/Shell/Extensions/Windows \
        org.gnome.Shell.Extensions.Windows.List \
        | jq -r --arg re "$1" '.[] | select(.title | test($re)) | .id' \
        | head -n1)
    if [ -z "$id" ]; then
        echo "MISSING:title:$1"
    else
        echo "$id"
    fi
}

# move_resize_window ID X Y WIDTH HEIGHT
#   Move and resize window ID. X/Y are signed pixel coords; WIDTH/HEIGHT
#   are unsigned. If ID is a "MISSING:..." sentinel from winid_from_class /
#   winid_from_title, skips with a warning naming what was searched for.
move_resize_window () {
    if [ "$#" -ne 5 ]; then
        echo "move_resize_window: expected 5 args (id x y w h), got $#; skipping" >&2
        return 0
    fi
    if [[ "$1" == MISSING:* ]]; then
        echo "move_resize_window: no window matching ${1#MISSING:}; skipping" >&2
        return 0
    fi
    gdbus call --session \
        --dest org.gnome.Shell \
        --object-path /org/gnome/Shell/Extensions/Windows \
        --method org.gnome.Shell.Extensions.Windows.MoveResize "$1" "$2" "$3" "$4" "$5" \
        > /dev/null
}

# raise_window ID
#   Activate (focus and raise) window ID.
raise_window () {
    gdbus call --session \
        --dest org.gnome.Shell \
        --object-path /org/gnome/Shell/Extensions/Windows \
        --method org.gnome.Shell.Extensions.Windows.Activate "$1"
}

# lswindows
#   Print one row per window with: id, title, class, x, y, width, height,
#   in aligned columns. Geometry comes from GetFrameRect (one dbus call
#   per window) since the installed extension's List output omits x/y/w/h.
lswindows () {
    {
        printf 'ID\tTITLE\tCLASS\tX\tY\tW\tH\n'
        dbus-send --session --print-reply=literal \
            --dest=org.gnome.Shell \
            /org/gnome/Shell/Extensions/Windows \
            org.gnome.Shell.Extensions.Windows.List \
            | jq -r '.[] | [.id, .title, .wm_class] | @tsv' \
            | while IFS=$'\t' read -r id title class; do
                rect=$(dbus-send --session --print-reply=literal \
                    --dest=org.gnome.Shell \
                    /org/gnome/Shell/Extensions/Windows \
                    org.gnome.Shell.Extensions.Windows.GetFrameRect "uint32:$id" 2>/dev/null)
                if [ -n "$rect" ]; then
                    read -r x y w h < <(echo "$rect" | jq -r '[.x, .y, .width, .height] | @tsv')
                else
                    x='?' y='?' w='?' h='?'
                fi
                printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$title" "$class" "$x" "$y" "$w" "$h"
            done
    } | column -t -s $'\t'
}

# arrange_dump
#   Print move_resize_window calls that would restore each current window
#   to its current position and size. Uses winid_from_class when the
#   window's class is unique among open windows; for windows that share a
#   class with another, falls back to winid_from_title with the window's
#   exact title (anchored, regex-escaped).
arrange_dump () {
    dbus-send --session --print-reply=literal \
        --dest=org.gnome.Shell \
        /org/gnome/Shell/Extensions/Windows \
        org.gnome.Shell.Extensions.Windows.List \
        | jq -r 'group_by(.wm_class)[] | length as $count | .[] | [.id, .title, .wm_class, $count] | @tsv' \
        | while IFS=$'\t' read -r id title class count; do
            rect=$(dbus-send --session --print-reply=literal \
                --dest=org.gnome.Shell \
                /org/gnome/Shell/Extensions/Windows \
                org.gnome.Shell.Extensions.Windows.GetFrameRect "uint32:$id" 2>/dev/null)
            [ -z "$rect" ] && continue
            read -r x y w h < <(echo "$rect" | jq -r '[.x, .y, .width, .height] | @tsv')
            if [ "$count" = "1" ]; then
                printf "move_resize_window \$(winid_from_class '%s') %s %s %s %s\n" \
                    "$class" "$x" "$y" "$w" "$h"
            else
                escaped=$(printf '%s' "$title" | sed -E 's/[].\\^$*+?()|{}[]/\\&/g')
                printf "move_resize_window \$(winid_from_title '^%s\$') %s %s %s %s\n" \
                    "$escaped" "$x" "$y" "$w" "$h"
            fi
        done
}

# workspace_height
#   Print the current display's vertical resolution in pixels (from Mutter).
workspace_height () {
    gdbus call --session \
        --dest org.gnome.Mutter.DisplayConfig \
        --object-path /org/gnome/Mutter/DisplayConfig \
        --method org.gnome.Mutter.DisplayConfig.GetCurrentState \
        | grep -oP --color=never "@60\.000', [0-9]+, \K[0-9]+"
}
